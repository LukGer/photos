---
import { BackButton } from "../../components/BackButton";
import { CrossfadeImage } from "../../components/CrossfadeImage";
import { ImageInfos } from "../../components/ImageInfos";
import { RetroToggle } from "../../components/RetroToggle";
import Layout from "../../layouts/Layout.astro";
import { getSortedMetadata, loadMetadata } from "../../lib/metadata";

export function getStaticPaths() {
	const items = loadMetadata();
	return items.map((item) => ({
		params: { slug: item.filename },
	}));
}

const { slug } = Astro.params;
const imageData = getSortedMetadata().find((item) => item.filename === slug);
---

<Layout title={imageData ? `${imageData.title} - Photos` : "Not found"}>
	{
		imageData ? (
			<div class="relative flex min-h-screen justify-center bg-black pt-[10vh]">
				<div class="absolute inset-x-0 top-0 z-20 flex flex-row items-center gap-3 p-4 px-[1.375rem]">
					<BackButton client:load />
					<div class="flex-1" />
					<RetroToggle client:load variant="dark" />
					<a href="https://lukger.dev" class="text-xs text-white/70">
						(c) 2025 Lukas Gerhold
					</a>
				</div>
				<div class="absolute bottom-4 left-4 z-10">
					<ImageInfos client:load image={imageData} />
				</div>
				<CrossfadeImage
					client:load
					fit="contain"
					blurSrc={imageData.blurDataURL}
					src={imageData.src}
					alt={imageData.filename}
					width={imageData.width}
					height={imageData.height}
					loading="eager"
				/>
			</div>
		) : (
			<div class="flex min-h-screen items-center justify-center">
				<div class="text-center">
					<h1 class="mb-2 text-2xl font-bold">Image not found</h1>
					<p class="text-gray-600">The requested image could not be found.</p>
				</div>
			</div>
		)
	}
</Layout>
